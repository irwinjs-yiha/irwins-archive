---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const writingPosts = await getCollection('writing');
const filmPosts = await getCollection('films');
const projectPosts = await getCollection('projects');

const sortedWriting = writingPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const sortedFilms = filmPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const sortedProjects = projectPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const recentWriting = sortedWriting.slice(0, 2);
const featuredFilm = sortedFilms[0];
const featuredProject = sortedProjects[0];

function formatDate(date: Date) {
return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

const timeline = [
{ img: '/01_early_childhood_garden_web.jpg', caption: 'Double Trouble', color: false, pos: 'center 58%', zoom: '220%' },
{ img: '/02_2010_aquarium_web.jpg', caption: 'Aquarium', color: false, pos: '32% 35%', zoom: 'cover' },
{ img: '/05_elementary_school_aktor_web.jpg', caption: 'What do you want to be, kid?', color: false, pos: 'center 30%', zoom: 'cover' },
{ img: '/06_2017_by_the_water_web.jpg', caption: 'San Francisco', color: false, pos: 'center 22%', zoom: 'cover' },
{ img: '/08_2022_last_year_jakarta_web.jpg', caption: 'Last Year in Jakarta', color: false, pos: 'center 18%', zoom: 'cover' },
{ img: '/09_2025_still_becoming_web.jpg', caption: 'Doge', color: true, pos: 'center 12%', zoom: 'cover' },
];
---

<BaseLayout activeNav="">

<!-- ══ HERO ══ -->
<section class="hero">
<div class="hero-inner">
<h1 class="hero-name">Irwin's<br/><em>Archive</em></h1>
<p class="hero-tag">Moments worth keeping.</p>
<p class="hero-quote">Life moves fast. Memory fades. This is my attempt to keep track of who I was, what I cared about, what I made, and who I was becoming.</p>
</div>
</section>

<!-- ══ FILM STRIP ══ -->
<div class="strip-wrap">

<div class="strip">
{[...timeline, ...timeline].map((item) => (
<div class={`frame ${item.color ? 'frame--color' : ''}`}>
<div class="frame-img" style={`background-image:url('${item.img}');background-position:${item.pos};background-size:${item.zoom};`}></div>
<div class="frame-info">
<span class="frame-caption">{item.caption}</span>
</div>
</div>
))}
</div>
</div>

<!-- ══ CONTENT ══ -->
<div class="content-body">

{recentWriting.length > 0 && (
<section class="grid-section reveal">
<div class="section-head">
<span class="section-lbl">Writing</span>
<a href="/writing" class="section-link">View all →</a>
</div>
<div class="writing-grid">
{recentWriting.map((post, i) => (
<a href={`/writing/${post.slug}`} class={`card ${i === 0 ? 'card--feat' : 'card--std'}`}>
<div class="card-media">
{post.data.cover
? <img src={post.data.cover} alt={post.data.title} loading="lazy"/>
: <div class="card-ph writing-ph"/>
}
</div>
<div class="card-body">
<span class="card-tag">Essay</span>
<h2 class="card-title">{post.data.title}</h2>
<span class="card-date">{formatDate(post.data.date)}</span>
</div>
</a>
))}
</div>
</section>
)}

{(featuredFilm || featuredProject) && (
<section class="grid-section reveal">
<div class="split-grid">
{featuredFilm && (
<a href={`/motion-pictures/${featuredFilm.slug}`} class="card card--split">
<div class="card-media">
{featuredFilm.data.poster
? <img src={featuredFilm.data.poster} alt={featuredFilm.data.title} loading="lazy"/>
: <div class="card-ph film-ph"/>
}
</div>
<div class="card-body">
<span class="card-tag">Film & TV</span>
<h2 class="card-title">{featuredFilm.data.title}</h2>
<span class="card-date">{formatDate(featuredFilm.data.date)}</span>
</div>
</a>
)}
{featuredProject && (
<a href={`/projects/${featuredProject.slug}`} class="card card--split">
<div class="card-media">
{featuredProject.data.cover
? <img src={featuredProject.data.cover} alt={featuredProject.data.title} loading="lazy"/>
: <div class="card-ph project-ph"/>
}
</div>
<div class="card-body">
<span class="card-tag">Project — {featuredProject.data.type}</span>
<h2 class="card-title">{featuredProject.data.title}</h2>
<span class="card-date">{formatDate(featuredProject.data.date)}</span>
</div>
</a>
)}
</div>
</section>
)}

</div>



</BaseLayout>

<style>
/* ── HERO ── */
.hero {
background: #0b0b0b;
padding: 4rem 4rem 2.5rem;
}
.hero-inner { max-width: 800px; }

.hero-name {
font-family: 'Cormorant Garamond', Georgia, serif;
font-size: clamp(3.5rem, 9vw, 7.5rem);
font-weight: 400;
color: #fff;
line-height: 1.0;
letter-spacing: -0.02em;
margin-bottom: 1.5rem;
}
.hero-name em { font-style: italic; color: rgba(255,255,255,0.3); }

.hero-tag {
font-size: 0.78rem;
color: rgba(255,255,255,0.28);
letter-spacing: 0.18em;
text-transform: uppercase;
font-weight: 300;
margin-bottom: 1.8rem;
}

.hero-quote {
font-family: 'Cormorant Garamond', Georgia, serif;
font-size: 1.15rem;
font-style: italic;
color: rgba(255,255,255,0.35);
max-width: 520px;
line-height: 1.7;
font-weight: 400;
}

/* ── FILM STRIP ── */
.strip-wrap {
background: #0b0b0b;
border-top: 1px solid #1c1c1c;
padding: 2rem 0 3rem;
overflow: hidden;
}

.strip-label {
font-size: 0.6rem;
letter-spacing: 0.26em;
text-transform: uppercase;
color: rgba(255,255,255,0.2);
padding: 0 4rem;
margin-bottom: 1.5rem;
}

.strip {
display: flex;
width: max-content;
animation: marquee 45s linear infinite;
}

.strip-wrap:hover .strip {
animation-play-state: paused;
}

@keyframes marquee {
0% { transform: translateX(0); }
100% { transform: translateX(-50%); }
}

.frame {
flex: 0 0 auto;
width: 180px;
margin-right: 10px;
cursor: default;
}

.frame-img {
width: 180px;
height: 240px;
background-repeat: no-repeat;
background-color: #111;
background-position: center top;
filter: grayscale(1) brightness(0.78);
transition: filter 0.4s, transform 0.4s;
}
.frame:hover .frame-img {
filter: grayscale(1) brightness(0.95);
transform: scale(1.02);
}
.frame--color .frame-img { filter: brightness(0.85); }
.frame--color:hover .frame-img { filter: brightness(1.0); }

.frame-info {
padding: 0.5rem 0 0;
}
.frame-caption {
font-size: 0.72rem;
color: rgba(255,255,255,0.5);
letter-spacing: 0.03em;
font-weight: 300;
}

/* ── CONTENT ── */
.content-body {
background: #f7f5f1;
color: #111;
}

.grid-section { padding: 5rem 4rem; border-bottom: 1px solid #e2ddd7; }

.section-head {
display: flex; justify-content: space-between; align-items: center;
padding-bottom: 1rem; margin-bottom: 2rem; border-bottom: 1px solid #e2ddd7;
}
.section-lbl { font-size: 0.62rem; letter-spacing: 0.24em; text-transform: uppercase; color: #b0a898; font-weight: 500; }
.section-link { font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: #b0a898; text-decoration: none; transition: color 0.2s; }
.section-link:hover { color: #111; }

.writing-grid { display: grid; grid-template-columns: 1.55fr 1fr; gap: 1.5rem; }
.split-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }

.card { display: block; text-decoration: none; color: inherit; }
.card-media { overflow: hidden; background: #e8e4dd; margin-bottom: 1.1rem; }
.card--feat .card-media { height: 400px; }
.card--std .card-media { height: 400px; }
.card--split .card-media { height: 280px; }

.card-media img {
width: 100%; height: 100%; object-fit: cover; display: block;
filter: saturate(0.8);
transition: transform 0.7s cubic-bezier(0.25,0.46,0.45,0.94), filter 0.4s;
}
.card:hover .card-media img { transform: scale(1.03); filter: saturate(1.0); }

.card-ph { width: 100%; height: 100%; transition: transform 0.7s; }
.card:hover .card-ph { transform: scale(1.03); }
.writing-ph { background: linear-gradient(135deg,#1a1a2e,#0f3460); }
.film-ph { background: linear-gradient(135deg,#2c1810,#6b3a2a); }
.project-ph { background: linear-gradient(135deg,#0d1f0d,#2d5228); }

.card-body { padding: 0 0.1rem; }
.card-tag { display: block; font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: #b0a898; margin-bottom: 0.5rem; }
.card-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.25rem; font-weight: 400; line-height: 1.3; letter-spacing: -0.01em; color: #111; margin-bottom: 0.5rem; transition: color 0.2s; }
.card--feat .card-title { font-size: 1.6rem; }
.card:hover .card-title { color: #555; }
.card-date { font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: #c8c0b4; }


@media (max-width: 820px) {
.hero { padding: 4rem 2rem 2.5rem; }
.strip-label { padding: 0 2rem; }
.grid-section { padding: 4rem 2rem; }
.writing-grid { grid-template-columns: 1fr; }
.split-grid { grid-template-columns: 1fr; }
.cat-link { font-size: 0.58rem; padding: 1rem; }
}
</style>
